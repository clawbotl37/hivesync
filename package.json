{
  "name": "hivesync",
  "version": "1.1.0",
  "description": "Secure Waku-based communication between Kai and other agents with real-time Obsidian sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hivesync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js start",
    "setup": "node dist/cli.js setup",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docs": "typedoc --out docs/api src/index.ts src/types/index.ts",
    "coverage": "jest --coverage",
    "heartbeat": "node heartbeat.js",
    "prepublishOnly": "npm run build && npm test",
    "docker:build": "docker build -t hivesync .",
    "docker:run": "docker run -it --rm hivesync",
    "docker:compose": "docker-compose up"
  },
  "keywords": [
    "hivesync",
    "waku",
    "decentralized",
    "communication",
    "kai",
    "obsidian",
    "p2p",
    "openclaw",
    "agent",
    "sync",
    "real-time",
    "file-sync"
  ],
  "author": "Kai Assistant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawbotl37/hivesync.git"
  },
  "bugs": {
    "url": "https://github.com/clawbotl37/hivesync/issues"
  },
  "homepage": "https://github.com/clawbotl37/hivesync#readme",
  "dependencies": {
    "js-waku": "^0.28.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "libp2p": "^0.46.0",
    "libp2p-noise": "^9.0.0",
    "libp2p-websockets": "^9.0.0",
    "multiformats": "^12.1.3",
    "commander": "^11.0.0",
    "chalk": "^4.1.2",
    "figlet": "^1.6.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "boxen": "^7.0.0",
    "yaml": "^2.3.0",
    "dotenv": "^16.0.0",
    "winston": "^3.10.0",
    "node-cron": "^3.0.2",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sqlite3": "^3.1.8",
    "@types/uuid": "^9.0.0",
    "@types/jest": "^29.0.0",
    "@types/inquirer": "^8.2.0",
    "@types/figlet": "^1.5.0",
    "@types/yaml": "^2.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "typedoc": "^0.24.0",
    "@types/boxen": "^5.1.0",
    "@types/node-cron": "^3.0.8",
    "@types/chokidar": "^2.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "examples",
    "openclaw-skill",
    "kai-integration",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  }
}
